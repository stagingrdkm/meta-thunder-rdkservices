Index: git/Source/core/ShutdownNotifier.h
===================================================================
--- /dev/null
+++ git/Source/core/ShutdownNotifier.h
@@ -0,0 +1,74 @@
+#include "Module.h"
+#include "Portability.h"
+
+#include <functional>
+#include <map>
+#include <atomic>
+#include <mutex>
+
+namespace WPEFramework {
+
+    namespace Core {
+
+        class EXTERNAL ShutdownNotifier {
+
+            public:
+
+                using ShutdownHandler = std::function<void(void)>;
+                using Handle = unsigned int;
+
+                class NotificationGuard {
+
+                    int handler_idx_;
+
+                    public:
+                        NotificationGuard(ShutdownHandler handler) : handler_idx_(ShutdownNotifier::Instance().addShutdownHandler(handler)) {
+                        }
+
+                        ~NotificationGuard() {
+                            ShutdownNotifier::Instance().removeShutdownHandler(handler_idx_);
+                        }
+                };
+
+                Handle addShutdownHandler(ShutdownHandler e) {
+                    static std::atomic_uint globalidx {0};
+                    unsigned int idx = ++globalidx;
+                    std::unique_lock<std::mutex> lock(m_);
+                    handlers_[idx] = e;
+                    return idx;
+                }
+
+                void removeShutdownHandler(Handle idx) {
+                    std::unique_lock<std::mutex> lock(m_);
+                    handlers_.erase(idx);
+                }
+
+                ~ShutdownNotifier() {
+                    // TODO: should we run the handlers?
+                }
+
+                static ShutdownNotifier& Instance();
+
+                void notifyShuttingDown() {
+                    std::unique_lock<std::mutex> lock(m_);
+                    if (!shuttingDown) {
+                        shuttingDown = true;
+                        for (auto& e : handlers_) {
+                            e.second();
+                        }
+                    }
+                }
+
+                bool isShuttingDown() {
+                    return shuttingDown;
+                }
+
+            private:
+
+                std::map<Handle, ShutdownHandler> handlers_;
+                std::mutex m_;
+                std::atomic_bool shuttingDown {false};
+        };
+
+    }
+}
