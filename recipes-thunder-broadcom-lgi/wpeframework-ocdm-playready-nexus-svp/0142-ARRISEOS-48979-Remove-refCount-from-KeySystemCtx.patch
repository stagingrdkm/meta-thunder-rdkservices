From 93ac3c222986ec481956a31946023c6f3e0877c2 Mon Sep 17 00:00:00 2001
From: Remya Das Pankan <rdaspankan.ext@libertyglobal.com>
Date: Thu, 26 Mar 2026 11:07:21 +0530
Subject: [PATCH] ARRISEOS-48979 Remove refCount from KeySystemCtx

Change-Id: I7e991b6ac9f77638d546830449429ffce60bed20
---
 MediaSystem.cpp | 58 ++++++++++++++++++-------------------------------
 1 file changed, 21 insertions(+), 37 deletions(-)

diff --git a/MediaSystem.cpp b/MediaSystem.cpp
index ad8a533..0287c64 100644
--- a/MediaSystem.cpp
+++ b/MediaSystem.cpp
@@ -91,7 +91,6 @@ struct KeySystemCtx
     std::array<uint8_t, MINIMUM_APPCONTEXT_OPAQUE_BUFFER_SIZE> opaqueBuffer{};
     std::array<uint8_t, REVOCATION_BUFFER_SIZE > revocationBuffer{};
     int32_t mediaKeySessionsCount{};
-    int32_t refCount{};
 };
 
 namespace {
@@ -284,13 +283,12 @@ public:
     CDMi_RESULT InitializeCtx(const std::string& keySystem) override
     {
         LOGGER(LINFO_, "Key system: %s", keySystem.c_str());
+        CDMi_RESULT cr = CDMi_SUCCESS;
         SafeCriticalSection systemLock(drmAppContextMutex_);
-        CDMi_RESULT cr = InitializeSystemRefCounted(keySystem);
-        if (cr == CDMi_SUCCESS) {
-            auto it = m_keySystemCtxs.find(keySystem);
-            ASSERT(it != m_keySystemCtxs.end());
-            it->second->refCount++;
-            LOGGER(LINFO_, "Key system: %s, ref count: %d\n", keySystem.c_str(), it->second->refCount);
+        if (m_keySystemCtxs.find(keySystem) == m_keySystemCtxs.end()) {
+            cr = InitializeSystem(keySystem);
+        } else {
+            LOGGER(LINFO_, "Key system %s already initialized", keySystem.c_str());
         }
         return cr;
     }
@@ -299,28 +297,18 @@ public:
     CDMi_RESULT DeinitializeCtx(const std::string& keySystem, bool cleanOnDestroy) override
     {
         LOGGER(LINFO_, "Key system: %s, clean on destroy: %d", keySystem.c_str(), cleanOnDestroy);
-        CDMi_RESULT cr = CDMi_SUCCESS;
         SafeCriticalSection systemLock(drmAppContextMutex_);
-        auto it = m_keySystemCtxs.find(keySystem);
-        if (it != m_keySystemCtxs.end()) {
-            LOGGER(LINFO_, "Key system: %s, ref count: %d, clean on destroy: %d", keySystem.c_str(), it->second->refCount, cleanOnDestroy);
-            it->second->refCount--;
-            DeinitializeSystemRefCounted(keySystem, cleanOnDestroy);
+        if (m_keySystemCtxs.find(keySystem) != m_keySystemCtxs.end()) {
+            DeinitializeSystem(keySystem, cleanOnDestroy);
         } else {
-            LOGGER_ODH(0, keySystem.c_str(), "No context found for the key system");
-            cr = CDMi_S_FALSE;
+            LOGGER(LINFO_, "No context found for the key system: %s", keySystem.c_str());
         }
-        return cr;
+        return CDMi_SUCCESS;
     }
 
-    CDMi_RESULT InitializeSystemRefCounted(const std::string& keySystem) {
+    CDMi_RESULT InitializeSystem(const std::string& keySystem) {
         CDMi_RESULT cr = CDMi_SUCCESS;
-        int count = 0;
-        auto it = m_keySystemCtxs.find(keySystem);
-        if (it != m_keySystemCtxs.end()) {
-            count = it->second->refCount;
-        }
-        if (count == 0) {
+        if (m_keySystemCtxs.find(keySystem) == m_keySystemCtxs.end()) {
             Stopwatch sw;
             if (m_drmOemContext == nullptr) {
                 cr = InitializePlatform();
@@ -328,10 +316,10 @@ public:
             if (cr == CDMi_SUCCESS) {
                 cr = CreateSystemExt(keySystem);
                 if (cr != CDMi_SUCCESS) {
-                    DeinitializeSystemRefCounted(keySystem);
+                    DeinitializeSystem(keySystem);
                 }
             }
-            LOGGER(LINFO_, "Initialization == %d took %.03f", static_cast<int>(cr), sw.elapsed());
+            LOGGER(LINFO_, "Initialization of %s key system took %.03f, result: %d", keySystem.c_str(), sw.elapsed(), static_cast<int>(cr));
         }
 
         return cr;
@@ -396,19 +384,17 @@ public:
     {
     }
 
-    void DeinitializeSystemRefCounted(const std::string& keySystem, bool cleanOnDestroy = true) {
+    void DeinitializeSystem(const std::string& keySystem, bool cleanOnDestroy = true) {
         auto it = m_keySystemCtxs.find(keySystem);
         ASSERT(it != m_keySystemCtxs.end());
-        if (it->second->refCount == 0) {
-            Stopwatch sw;
-            if (cleanOnDestroy) {
-                CleanSecureStoreUnlocked(keySystem);
-            }
-            Drm_Uninitialize(&it->second->drmAppctx);
-            m_keySystemCtxs.erase(it);
-            DeinitializePlatform();
-            LOGGER(LINFO_, "Deinitialization of %s key system took %.03f", keySystem.c_str(), sw.elapsed());
+        Stopwatch sw;
+        if (cleanOnDestroy) {
+            CleanSecureStoreUnlocked(keySystem);
         }
+        Drm_Uninitialize(&it->second->drmAppctx);
+        m_keySystemCtxs.erase(it);
+        DeinitializePlatform();
+        LOGGER(LINFO_, "Deinitialization of %s key system took %.03f", keySystem.c_str(), sw.elapsed());
     }
 
     CDMi_RESULT ReinitializeSystem(const std::string& keySystem)
@@ -417,7 +403,6 @@ public:
 
         auto it = m_keySystemCtxs.find(keySystem);
         ASSERT(it != m_keySystemCtxs.end());
-        auto oldRefCount = it->second->refCount;
         Drm_Uninitialize(&it->second->drmAppctx);
         m_keySystemCtxs.erase(it);
 
@@ -425,7 +410,6 @@ public:
 
         it = m_keySystemCtxs.find(keySystem);
         ASSERT(it != m_keySystemCtxs.end());
-        it->second->refCount = oldRefCount;
 
         return cr;
     }
-- 
2.34.1

